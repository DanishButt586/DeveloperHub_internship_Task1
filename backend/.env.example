# =========================================
# BACKEND ENVIRONMENT VARIABLES
# Production Level Configuration for Vercel
# =========================================

# Database Configuration
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/developerhub?retryWrites=true&w=majority

# Database Name
DB_NAME=developerhub

# Node Environment (use "production" for Vercel deployment)
NODE_ENV=production

# CORS Origin - Comma-separated list of allowed frontend origins
# For production: https://your-frontend-project.vercel.app
# For local development: http://localhost:5173
CORS_ORIGIN=https://your-frontend-vercel-url.vercel.app

# Optional: Fallback MongoDB Connection String
# Leave commented unless you need a secondary connection for failover
# MONGO_URI_FALLBACK=mongodb://backup-user:backup-password@backup-host:27017/developerhub?authSource=admin

# Port for local development only (Vercel uses serverless functions)
PORT=5000

# =========================================
# SETUP INSTRUCTIONS
# =========================================
# 1. Create MongoDB Atlas account: https://www.mongodb.com/cloud/atlas
# 2. Create a free M0 cluster
# 3. Add database user with strong password
# 4. Whitelist your IP or use 0.0.0.0/0 for development
# 5. Click "Connect" -> "Drivers" and copy connection string
# 6. Replace username and password in MONGO_URI
# 7. Set DB_NAME to "developerhub"
# 8. For Vercel: Set CORS_ORIGIN to your frontend Vercel URL
# 9. Ensure NODE_ENV is "production" for Vercel deployment

# =========================================
# HARDCODED COUPONS (Auto-seeded on startup)
# =========================================
# 233606DA -> 50% discount
# 233544SA -> 35% discount
# These are automatically created in MongoDB on first run
