# =========================================
# FRONTEND ENVIRONMENT VARIABLES
# Production Level Configuration for Vercel
# =========================================

# Backend API Base URL
# For production (Vercel): https://your-backend-project.vercel.app/api
# For local development: http://localhost:5000/api
VITE_API_BASE_URL=https://your-backend-vercel-url.vercel.app/api

# =========================================
# SETUP INSTRUCTIONS
# =========================================
# 1. Use your backend URL from Vercel deployment
# 2. Example: https://developerhub-backend.vercel.app/api
# 3. Make sure to include "/api" at the end
# 4. For local development, use http://localhost:5000/api
# 5. This URL is used by the frontend to make API calls

# =========================================
# NOTES
# =========================================
# - VITE_API_BASE_URL must be accessible from the browser
# - Ensure backend CORS_ORIGIN allows your frontend URL
# - Use HTTPS URLs for production
# - Use HTTP localhost for local development
